project('retro-book-trickswindowsgamegurus', 'cpp',
  default_options: ['warning_level=1', 'buildtype=debug'])

sdl2 = dependency('sdl2')

link_args = []
if host_machine.system() == 'darwin'
  link_args += ['-Wl,-undefined,dynamic_lookup']
endif

